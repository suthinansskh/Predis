# ==========================================
# Predis MCP Server — Configuration
# ==========================================
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าจริง

# Google Sheets Spreadsheet ID
# หาจาก URL: https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# Google Service Account Credentials (JSON string หรือ path)
# วิธีที่ 1: ใส่ path ไปยังไฟล์ credentials JSON
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# วิธีที่ 2: ใส่ JSON content โดยตรง (สำหรับ deploy บน server)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ชื่อ Sheet (เปลี่ยนได้ตามความต้องการ)
SHEET_ERRORS=Predispensing_Errors
SHEET_USERS=Users
SHEET_DRUGS=Drug_List

# ==========================================
# วิธีสร้าง Service Account:
# 1. ไป https://console.cloud.google.com
# 2. สร้าง Project ใหม่ (หรือใช้ที่มีอยู่)
# 3. เปิด Google Sheets API
# 4. IAM & Admin → Service Accounts → Create
# 5. Create Key → JSON → Download
# 6. Share Google Sheet ให้ email ของ Service Account (Editor)
# ==========================================

# MySQL Database (for drug list sync)
MYSQL_HOST=14.11.0.3
MYSQL_USER=drug_queue
MYSQL_PASSWORD=drug_queue@drug_queue
MYSQL_DATABASE=hos
