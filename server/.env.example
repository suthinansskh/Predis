# ==========================================
# Predis API Server — Configuration
# ==========================================
# Copy this file to .env and fill in actual values

PORT=3000

# CORS origin (set to your frontend URL in production)
CORS_ORIGIN=*

# Google Sheets
SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# MySQL Database (for drug list sync)
MYSQL_HOST=14.11.0.3
MYSQL_USER=drug_queue
MYSQL_PASSWORD=drug_queue@drug_queue
MYSQL_DATABASE=hos
